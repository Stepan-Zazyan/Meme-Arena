{
  "info": {
    "name": "Meme Arena",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Create Guest",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/users/guest",
            "body": {
              "mode": "raw",
              "raw": "{\"nickname\":\"Stepan{{$timestamp}}\",\"installationId\":\"postman-installation-id\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "pm.environment.set('accessToken', json.session.accessToken);",
                  "pm.environment.set('userId', json.user.id);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/me/logout"
          }
        }
      ]
    },
    {
      "name": "Battle",
      "item": [
        {
          "name": "Next Battle",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/battles/next"
          }
        }
      ]
    },
    {
      "name": "Media",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/media/images"
          }
        }
      ]
    },
    {
      "name": "Meme",
      "item": [
        {
          "name": "Create Meme",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/memes",
            "body": {
              "mode": "raw",
              "raw": "{\"title\":\"Postman meme\",\"mediaAssetId\":\"{{mediaAssetId}}\",\"sourceUrl\":null}"
            }
          }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Top Memes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/memes/top?period=ALL_TIME&limit=20"
          }
        }
      ]
    },
    {
      "name": "Admin Moderation",
      "item": [
        {
          "name": "Queue",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/moderation/memes"
          }
        },
        {
          "name": "Approve",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{adminToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/moderation/memes/{{memeId}}/approve"
          }
        }
      ]
    },
    {
      "name": "Security Tests",
      "item": [
        {
          "name": "Protected without token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Protected garbage token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "garbage",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Admin with user token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/moderation/memes"
          }
        },
        {
          "name": "Admin without token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/admin/moderation/memes"
          }
        },
        {
          "name": "Logout revokes token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/users/me/logout"
          }
        },
        {
          "name": "After logout returns 401",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        }
      ]
    },
    {
      "name": "Scout System",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me"
          }
        },
        {
          "name": "Get My Pending Predictions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me/predictions?status=PENDING&page=0&size=20"
          }
        },
        {
          "name": "Get My Successful Predictions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me/predictions?status=SUCCESS&page=0&size=20"
          }
        },
        {
          "name": "Get Scout Leaderboard WEEK",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/leaderboard?period=WEEK&limit=50"
          }
        },
        {
          "name": "Get Scout Leaderboard ALL_TIME",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/leaderboard?period=ALL_TIME&limit=50"
          }
        },
        {
          "name": "Admin Resolve Predictions",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/admin/scout/resolve"
          }
        }
      ]
    }
  ]
}