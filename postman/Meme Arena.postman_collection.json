{
  "info": {"name": "Meme Arena", "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"},
  "item": [{"name": "Health", "request": {"method": "GET", "header": [], "url": {"raw": "{{baseUrl}}/api/v1/health", "host": ["{{baseUrl}}"], "path": ["api", "v1", "health"]}},
    "event": [{"listen": "test", "script": {"exec": [
      "pm.test('HTTP status is 200', () => pm.response.to.have.status(200));",
      "pm.test('status is UP', () => pm.expect(pm.response.json().status).to.eql('UP'));",
      "pm.test('service is meme-arena-backend', () => pm.expect(pm.response.json().service).to.eql('meme-arena-backend'));",
      "pm.test('timestamp is present', () => pm.expect(pm.response.json().timestamp).to.be.ok);",
      "pm.test('X-Request-Id is present', () => pm.expect(pm.response.headers.has('X-Request-Id')).to.be.true);"
    ]}}]}]
}
